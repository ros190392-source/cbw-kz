# ============================================================
# CBW KZ — Environment configuration
# Copy this file to ".env" and fill in real values.
# ============================================================

# --- Telegram ---------------------------------------------------
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Private moderation chat ID where DRAFTS are sent for approval.
# For a private chat with the bot it is your numeric user id.
# For a private group/channel it is a negative number (e.g. -1001234567890).
TELEGRAM_MODERATION_CHAT_ID=

# Public channel where APPROVED posts are published. Use the @username for a
# public channel (e.g. @cbw_kz) or the numeric id for a private one
# (e.g. -1001234567890). The bot must be an admin of this channel. Publishing
# only ever happens after an explicit manual Approve click / manual run of
# `npm run publish` — there is NO auto-posting.
TELEGRAM_CHANNEL_ID=@cbw_kz

# Comma-separated numeric Telegram user ids allowed to Approve/Reject.
# ONLY these users can publish. If empty, nobody can approve (safe default).
# Find your id by sending /start to the bot — it replies with the chat id.
TELEGRAM_ADMIN_IDS=

# --- AI rewrite layer (OpenAI-compatible) -----------------------
# Works with OpenAI, OpenRouter, Together, local LLMs, etc.
# Leave OPENAI_API_KEY empty to run in safe fallback mode (no AI call,
# deterministic formatting) — useful for testing the pipeline offline.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Premium image generation (EPIC 017) ------------------------
# Which provider generates premium post images: fal | openai | none.
# With "none" (default) the content machine uses the fallback images in
# assets/telegram/kartinki-dlya-postov/. No image is ever auto-published.
IMAGE_PROVIDER=none
# fal.ai key (when IMAGE_PROVIDER=fal)
FAL_KEY=
# OpenAI image key (when IMAGE_PROVIDER=openai). Falls back to OPENAI_API_KEY.
OPENAI_IMAGE_KEY=
# OpenAI image model + size (defaults shown). gpt-image-1 sizes: 1024x1024,
# 1536x1024 (landscape), 1024x1536. dall-e-3: 1792x1024, 1024x1024, 1024x1792.
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1536x1024
# Optional override for the images base URL (defaults to OPENAI_BASE_URL).
OPENAI_IMAGE_BASE_URL=
# Watermark text composited (bottom-right) onto every generated image.
BRAND_WATERMARK=CryptoBonusWorld.com
# Overlay the round CBW KZ logo badge (top-centre). Default off.
BRAND_LOGO=false

# --- Engagement signals (EPIC 022) ------------------------------
# Free CryptoPanic API token (https://cryptopanic.com/developers/api/) for
# community-vote heat on hot stories. Optional — without it the engagement
# layer still works from Reddit r/CryptoCurrency hot (no key required).
CRYPTOPANIC_KEY=

# Autopublish lane: news (global, 3 UTC slots) | roadmap (legacy KZ lane).
AUTOPUBLISH_MODE=news

# --- Pipeline tuning --------------------------------------------
# How often the bot runs the pipeline (milliseconds). Default 5 min.
POLL_INTERVAL_MS=300000

# Minimum moderation score required to pass (higher = stricter).
MODERATION_MIN_SCORE=3

# Max number of NEW drafts produced per run (rate-limit protection).
MAX_ITEMS_PER_RUN=10

# --- Production runtime (EPIC 011) ------------------------------
# Environment: development | production
NODE_ENV=development

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# HTTP health-check port. 0 disables the health server (default).
# When set (e.g. 8080), GET /health returns a JSON health report.
HEALTHCHECK_PORT=0

# Directory for timestamped JSON backups. Default: ./backups
BACKUP_DIR=./backups

# How many backups to retain (older ones are pruned). Default: 7
BACKUP_RETENTION=7

# Send admin/moderation alerts (startup, shutdown, health red, errors).
# Alerts are notification-only — they never take any action. Default: false.
ALERTS_ENABLED=false
